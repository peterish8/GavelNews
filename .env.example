# ─── Data source ────────────────────────────────────────────────────────────
# Leave DATA_SOURCE=mock (default) for local dev without a Supabase project.
# Set to "supabase" once your Supabase project is provisioned (Phase 5).
DATA_SOURCE=mock

# ─── Supabase (Phase 5) ─────────────────────────────────────────────────────
# Browser-safe — both must be NEXT_PUBLIC_ so client components can read them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client. Used by service-role calls
# (admin tasks). NEVER import this into a client component.
SUPABASE_SERVICE_ROLE_KEY=
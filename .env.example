# ─── Data source ────────────────────────────────────────────────────────────
# Leave DATA_SOURCE=mock (default) for local dev without a Supabase project.
# Set to "supabase" once your Supabase project is provisioned.
#
# IMPORTANT: this app holds ONLY the Supabase anon key. The service-role key
# belongs to the gavel-news engine repo (the only writer to
# `published_stories`) and must never exist in this codebase — not even as
# an empty placeholder. Per PLAT-03.
DATA_SOURCE=mock

# ─── Supabase (anon only) ───────────────────────────────────────────────────
# Browser-safe — both must be NEXT_PUBLIC_ so client components can read them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
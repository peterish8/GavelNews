# ─── Data source ────────────────────────────────────────────────────────────
# Leave DATA_SOURCE=mock (default) for local dev without a Supabase project.
# Set to "supabase" once your Supabase project is provisioned.
DATA_SOURCE=mock

# ─── Site URL ────────────────────────────────────────────────────────────────
# Drives metadataBase, canonical URLs, and share links (lib/site.ts). Defaults
# to http://localhost:3000 in dev if unset — set to the real production
# domain (e.g. https://gavel.news) when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Anon key is browser-safe — both NEXT_PUBLIC_ vars can reach client components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Per PLAT-03, updated): reads full gated story/PYQ content via
# lib/supabase/serviceRole.ts, only when user.signedIn is true. NEVER prefix
# with NEXT_PUBLIC_ — that would ship it to the browser. That file has
# `import "server-only"` so an accidental client-side import fails the build.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth (Google OAuth via Supabase) ───────────────────────────────────────
# 1. Supabase Dashboard → Authentication → Providers → Google → enable
# 2. Google Cloud Console → OAuth client (Web) → authorized redirect URI:
#      https://<PROJECT_REF>.supabase.co/auth/v1/callback
# 3. Supabase → Authentication → URL Configuration:
#      Site URL = NEXT_PUBLIC_SITE_URL (e.g. http://localhost:3000)
#      Redirect allowlist must include:
#        http://localhost:3000/auth/callback
#        https://your-production-domain/auth/callback
# App flow: /auth/signin → signInWithGoogle → Google → /auth/callback → session cookies.